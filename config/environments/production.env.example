APP_ENV=production
APP_NAME=AiClod
APP_DOMAIN=aiclod.example
DEFAULT_PLATFORM_LOCALE=en-US
SUPPORTED_LOCALES=en-US,es-ES,fr-FR,de-DE,ar-SA
DEFAULT_TIMEZONE=UTC
SUPPORTED_TIMEZONES=UTC,America/New_York,Europe/London,Europe/Berlin,Asia/Dubai,Asia/Singapore
DEFAULT_CURRENCY=USD
SUPPORTED_CURRENCIES=USD,EUR,GBP,CAD,AUD,SGD,AED
JOB_APPLICATION_REGIONS=US,CA,GB,DE,FR,AE,SG
JWT_ISSUER=https://auth.aiclod.example/realms/aiclod
JWT_AUDIENCE=aiclod-api
JWT_JWKS_URI=https://auth.aiclod.example/realms/aiclod/protocol/openid-connect/certs
DATABASE_URL=postgresql://aiclod:aiclod@postgres:5432/aiclod
REDIS_URL=redis://valkey:6379
RABBITMQ_URL=amqp://aiclod:aiclod@rabbitmq:5672
OPENSEARCH_URL=http://opensearch:9200
S3_ENDPOINT=http://minio:9000
S3_BUCKET=aiclod-production
S3_REGION=us-east-1
KEYCLOAK_BASE_URL=https://auth.aiclod.example
CHAT_TRANSPORT=websocket
CHAT_WS_BASE_URL=wss://api.aiclod.example/ws
NOTIFICATION_PROVIDER=database,rabbitmq,email
NOTIFICATION_DIGEST_TIME=08:00
EMAIL_PROVIDER=smtp
EMAIL_FROM_NAME=AiClod
EMAIL_FROM_ADDRESS=no-reply@aiclod.example
SMTP_HOST=smtp.aiclod.example
SMTP_PORT=587
AI_FEATURES_ENABLED=true
AI_PROVIDER=openai-compatible
AI_GATEWAY_BASE_URL=https://ai.aiclod.example
AI_VECTOR_STORE=opensearch
JOB_RECOMMENDATION_MODEL=job-recommender-v1
RESUME_SCORING_MODEL=resume-ranker-v1
SKILL_GAP_MODEL=skill-gap-analyst-v1
PREDICTIVE_HIRING_MODEL=hiring-forecast-v1
CHATBOT_MODEL=candidate-assistant-v1
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
JWT_ISSUER=https://auth.aiclod.example/realms/aiclod
JWT_AUDIENCE=aiclod-api
JWT_JWKS_URI=https://auth.aiclod.example/realms/aiclod/protocol/openid-connect/certs
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/aiclod
REDIS_URL=redis://<host>:6379
RABBITMQ_URL=amqps://<user>:<password>@<host>:5671
OPENSEARCH_URL=https://search.aiclod.example
S3_ENDPOINT=https://s3.aiclod.example
S3_BUCKET=aiclod-prod
S3_REGION=us-east-1
KEYCLOAK_BASE_URL=https://auth.aiclod.example
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability:4318
