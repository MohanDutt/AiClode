APP_ENV=staging
APP_NAME=AiClod
APP_DOMAIN=staging.aiclod.example
DEFAULT_PLATFORM_LOCALE=en-US
SUPPORTED_LOCALES=en-US,es-ES,fr-FR,de-DE,ar-SA
DEFAULT_TIMEZONE=UTC
SUPPORTED_TIMEZONES=UTC,America/New_York,Europe/London,Europe/Berlin,Asia/Dubai,Asia/Singapore
DEFAULT_CURRENCY=USD
SUPPORTED_CURRENCIES=USD,EUR,GBP,CAD,AUD,SGD,AED
JOB_APPLICATION_REGIONS=US,CA,GB,DE,FR,AE,SG
JWT_ISSUER=https://auth.staging.aiclod.example/realms/aiclod
JWT_AUDIENCE=aiclod-api
JWT_JWKS_URI=https://auth.staging.aiclod.example/realms/aiclod/protocol/openid-connect/certs
DATABASE_URL=postgresql://aiclod:aiclod@postgres:5432/aiclod
REDIS_URL=redis://valkey:6379
RABBITMQ_URL=amqp://aiclod:aiclod@rabbitmq:5672
OPENSEARCH_URL=http://opensearch:9200
S3_ENDPOINT=http://minio:9000
S3_BUCKET=aiclod-staging
S3_REGION=us-east-1
KEYCLOAK_BASE_URL=https://auth.staging.aiclod.example
CHAT_TRANSPORT=websocket
CHAT_WS_BASE_URL=wss://api.staging.aiclod.example/ws
NOTIFICATION_PROVIDER=database,rabbitmq,email
NOTIFICATION_DIGEST_TIME=08:00
EMAIL_PROVIDER=smtp
EMAIL_FROM_NAME=AiClod
EMAIL_FROM_ADDRESS=no-reply@staging.aiclod.example
SMTP_HOST=smtp.staging.aiclod.example
SMTP_PORT=587
AI_FEATURES_ENABLED=true
AI_PROVIDER=openai-compatible
AI_GATEWAY_BASE_URL=https://ai.staging.aiclod.example
AI_VECTOR_STORE=opensearch
JOB_RECOMMENDATION_MODEL=job-recommender-v1
RESUME_SCORING_MODEL=resume-ranker-v1
SKILL_GAP_MODEL=skill-gap-analyst-v1
PREDICTIVE_HIRING_MODEL=hiring-forecast-v1
CHATBOT_MODEL=candidate-assistant-v1
ADMIN_CONSOLE_ENABLED=true
ADMIN_API_BASE_URL=https://api.staging.aiclod.example/api/v1/admin
ADMIN_FRAUD_QUEUE=admin.fraud.review
ADMIN_ANALYTICS_PROVIDER=postgres
ADMIN_REVENUE_CURRENCY=USD
FEATURE_FLAG_PROVIDER=config
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
