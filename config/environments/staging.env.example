APP_ENV=staging
APP_NAME=AiClod
APP_DOMAIN=staging.aiclod.example
JWT_ISSUER=https://auth.staging.aiclod.example/realms/aiclod
JWT_AUDIENCE=aiclod-api
JWT_JWKS_URI=https://auth.staging.aiclod.example/realms/aiclod/protocol/openid-connect/certs
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/aiclod
REDIS_URL=redis://<host>:6379
RABBITMQ_URL=amqps://<user>:<password>@<host>:5671
OPENSEARCH_URL=https://search.staging.aiclod.example
S3_ENDPOINT=https://s3.staging.aiclod.example
S3_BUCKET=aiclod-staging
S3_REGION=us-east-1
KEYCLOAK_BASE_URL=https://auth.staging.aiclod.example
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability:4318
