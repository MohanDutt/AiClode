subject: Your application for {{ job_title }} was received
body_html: |
  <p>Hello {{ candidate_name }},</p>
  <p>We received your application for <strong>{{ job_title }}</strong>.</p>
  <p>You can review the current status in your AiClod dashboard.</p>
  <p>Timezone: {{ candidate_timezone }} | Preferred language: {{ locale }}</p>
